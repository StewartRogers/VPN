# Copy to .env and fill in — .env is gitignored and loaded automatically on startup.

# Required to enable API authentication (Bearer token). Leave unset and the API is open.
VPN_API_TOKEN=

# Optional: home/ISP IP to monitor against. Can also be passed as a CLI arg.
HOME_IP=

# Optional: interface to bind the Flask server to. Defaults to 0.0.0.0 (all interfaces).
BIND_HOST=0.0.0.0
